<?xml version="1.0" encoding="UTF-8"?>
<!-- Kathmandu traffic mix: shares approximate Department of Transport
     Management vehicle-registration ratios (motorbikes dominate the valley).
     Loaded as an additional file BEFORE the route files so randomTrips can
     assign type="kathmanduMix" to every generated trip. -->
<additional>
    <vTypeDistribution id="kathmanduMix">
        <vType id="motorbike" vClass="motorcycle" probability="0.45"
               length="2.2" width="0.9" height="1.4"
               accel="3.0" decel="6.0" maxSpeed="19.4" sigma="0.7"
               minGap="1.0" guiShape="motorcycle" color="0.85,0.33,0.10"/>
        <vType id="car" vClass="passenger" probability="0.30"
               length="4.3" width="1.8" height="1.5"
               accel="2.6" decel="4.5" maxSpeed="27.8" sigma="0.5"
               minGap="2.0" guiShape="passenger" color="0.16,0.47,0.84"/>
        <vType id="microbus" vClass="passenger" probability="0.10"
               length="5.5" width="2.0" height="2.3"
               accel="1.8" decel="4.0" maxSpeed="22.2" sigma="0.6"
               minGap="2.2" guiShape="bus" color="0.98,0.70,0.10"/>
        <vType id="bus" vClass="bus" probability="0.07"
               length="12.0" width="2.5" height="3.2"
               accel="1.2" decel="4.0" maxSpeed="19.4" sigma="0.4"
               minGap="2.5" guiShape="bus" color="0.06,0.64,0.48"/>
        <vType id="truck" vClass="truck" probability="0.08"
               length="8.5" width="2.4" height="3.0"
               accel="1.3" decel="4.0" maxSpeed="19.4" sigma="0.4"
               minGap="2.5" guiShape="truck" color="0.45,0.45,0.50"/>
    </vTypeDistribution>
</additional>
